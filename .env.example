# Скопируйте в .env и при необходимости измените:
#   cp .env.example .env
#
# Docker Compose читает .env автоматически.
# Секреты Telegram / OpenRouter / SerpAPI — только в UI n8n (Credentials).
# Не коммитьте .env с реальными значениями.

# --- Docker / n8n ---
N8N_PORT=5678
N8N_HOST=localhost
N8N_PROTOCOL=http
N8N_EDITOR_BASE_URL=http://localhost:5678

# URL, по которому Telegram и webhooks достучатся до n8n.
# Локально без туннеля бот не получит сообщения — см. docs/DOCKER.md
WEBHOOK_URL=http://localhost:5678/

# Опционально: базовая авторизация в UI n8n
N8N_BASIC_AUTH_ACTIVE=false
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change-me

# false для http://localhost; true если n8n за HTTPS-прокси
N8N_SECURE_COOKIE=false

TZ=Europe/Moscow

# --- Справочно (вводятся в n8n Credentials, не в compose) ---
TELEGRAM_BOT_TOKEN=
OPENROUTER_API_KEY=
SERPAPI_API_KEY=
